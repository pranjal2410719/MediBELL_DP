# MediBELL Environment Variables

# Simulation Toggles (True/False)
BLOCKCHAIN_SIMULATION_MODE=False
IPFS_SIMULATION_MODE=True

# IPFS Pinata Configuration (Required if IPFS_SIMULATION_MODE=False)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_key

# Web3 / Ethereum Node RPC URL (Ganache defaults to http://127.0.0.1:8545)
WEB3_PROVIDER_URL=http://127.0.0.1:8545

# Ethereum Contract Address (leave blank to read from blockchain/deployed_address.txt)
CONTRACT_ADDRESS=

# Private Key of the deployment account (leave blank to use Ganache's unlocked account[0])
PRIVATE_KEY=
